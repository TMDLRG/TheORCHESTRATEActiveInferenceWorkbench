# Elixir build artefacts
/_build/
/cover/
/deps/
/doc/
/.fetch
erl_crash.dump
*.ez
mix.lock.backup
.elixir_ls/
.elixir-tools/
/config/*.secret.exs

# Generated by tools/librechat_seed/export_agent_ids.py (per-environment Mongo agent ids).
apps/workbench_web/priv/librechat/agents.json

# Phoenix generated files
apps/*/priv/static/cache_manifest.json
apps/*/priv/static/assets/*
!apps/*/priv/static/assets/.keep
# Hand-authored static assets (not build artefacts) -- must ship on fresh clone.
!apps/*/priv/static/assets/app.js
!apps/*/priv/static/assets/voice-autoplay.js
!apps/*/priv/static/assets/suite-tokens.css
!apps/*/priv/static/assets/composition_canvas.js

# Mnesia on-disk event log
/priv/mnesia/
/apps/*/priv/mnesia/
