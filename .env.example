# Copy to `.env` and fill in. `.env` is gitignored.
#
# Generate a SECRET_KEY_BASE with any of:
#
#   cd active_inference && mix phx.gen.secret
#   openssl rand -base64 48
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
#
# Must be at least 64 characters.
SECRET_KEY_BASE=replace-me-with-a-64-plus-character-secret-generated-from-mix-phx-gen-secret

# Public hostname used in generated URLs. For purely local use leave as
# localhost. For a Cloudflare Tunnel or similar, set to the public host
# (e.g. orcworkbench.example.com).
PHX_HOST=localhost
